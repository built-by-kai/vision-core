{
  "version": 2,
  "builds": [
    {"src": "api/generate.py",              "use": "@vercel/python"},
    {"src": "api/cal_booking.py",           "use": "@vercel/python"},
    {"src": "api/implementation_form.py",   "use": "@vercel/python"},
    {"src": "api/generate_invoice.py",      "use": "@vercel/python"},
    {"src": "api/create_invoice.py",        "use": "@vercel/python"},
    {"src": "api/generate_receipt.py",      "use": "@vercel/python"},
    {"src": "api/send_quotation.py",        "use": "@vercel/python"},
    {"src": "api/create_quotation.py",      "use": "@vercel/python"},
    {"src": "api/deposit_paid.py",          "use": "@vercel/python"},
    {"src": "api/issue_final_invoice.py",   "use": "@vercel/python"},
    {"src": "api/expansion_invoice.py",     "use": "@vercel/python"},
    {"src": "api/wa_redirect.py",           "use": "@vercel/python"},
    {"src": "api/create_addon.py",          "use": "@vercel/python"}
  ],
  "routes": [
    {"src": "/api/generate",                "dest": "api/generate.py"},
    {"src": "/api/cal_booking",             "dest": "api/cal_booking.py"},
    {"src": "/api/implementation_form",     "dest": "api/implementation_form.py"},
    {"src": "/api/generate_invoice",        "dest": "api/generate_invoice.py"},
    {"src": "/api/create_invoice",          "dest": "api/create_invoice.py"},
    {"src": "/api/generate_receipt",        "dest": "api/generate_receipt.py"},
    {"src": "/api/send_quotation",          "dest": "api/send_quotation.py"},
    {"src": "/api/create_quotation",        "dest": "api/create_quotation.py"},
    {"src": "/api/deposit_paid",            "dest": "api/deposit_paid.py"},
    {"src": "/api/issue_final_invoice",     "dest": "api/issue_final_invoice.py"},
    {"src": "/api/expansion_invoice",       "dest": "api/expansion_invoice.py"},
    {"src": "/api/wa_redirect",             "dest": "api/wa_redirect.py"},
    {"src": "/api/create_addon",            "dest": "api/create_addon.py"}
  ]
}
