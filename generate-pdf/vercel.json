{
  "version": 2,
  "builds": [
    {
      "src": "api/generate.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/cal_booking.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/implementation_form.py",
      "use": "@vercel/python"
